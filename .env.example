# Backend Database and Authentication
DB_URL=jdbc:postgresql://db:5432/webGIS_DB
DB_USER=webgis_client
DB_PASSWORD=changeme_strong_password
JWT_SECRET=changeme_base64_encoded_secret_min_32_chars
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Docker Compose - Database Service
POSTGRES_USER=root
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=webGIS_DB

# Docker Compose - GeoServer Service
GEOSERVER_ADMIN_PASSWORD=changeme_geoserver_password

# Docker Compose - pgAdmin Service
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme_pgadmin_password

